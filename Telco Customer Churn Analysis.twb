      <aliases enabled='yes' />
      <column caption='Churn Rate' datatype='real' default-format='p0.00%' name='[Calculation_1625683474870273]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn] = &apos;Yes&apos; THEN 1.0 ELSE 0.0 END) / COUNTD([customerID])' />
      </column>
      <column caption='Churned' datatype='real' name='[Calculation_1625683477508098]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Churn] = &apos;Yes&apos; THEN 1.0 ELSE 0.0 END)' />
      </column>
      <column caption='Revenue at Risk/Month' datatype='real' name='[Calculation_1625683479269379]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM(IF [Churn] = &apos;Yes&apos; THEN [MonthlyCharges] END))' />
      </column>
